# ================================
# LearnHub Environment Variables
# ================================
# Copy this file to .env and fill in your values

# === DATABASE ===
DATABASE_URL="postgresql://learnhub:learnhub_secret@localhost:5432/learnhub"

# === REDIS ===
REDIS_URL="redis://localhost:6379"

# === JWT SECRETS ===
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"

# === GROQ AI (FREE) ===
# Get your free API key at: https://console.groq.com
# Free tier: 14,400 requests/day — more than enough for MVP
GROQ_API_KEY="gsk_your_groq_api_key_here"

# Groq model to use — these are free:
#   llama-3.3-70b-versatile  (best quality, recommended)
#   llama-3.1-8b-instant     (faster, lower quality)
#   mixtral-8x7b-32768       (good alternative)
#   gemma2-9b-it             (Google's model)
GROQ_MODEL="llama-3.3-70b-versatile"

# === HUGGING FACE (FREE) — for RAG embeddings ===
# Get your free API key at: https://huggingface.co/settings/tokens
# Free tier is sufficient for MVP usage
# If left empty, RAG will still work but with text-based fallback (no vector search)
HUGGINGFACE_API_KEY="hf_your_huggingface_token_here"

# === GOOGLE OAUTH (optional) ===
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === URLS ===
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# === AWS S3 (optional for file uploads) ===
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# === APP ===
PORT=4000
NODE_ENV="development"

# === FRONTEND (Next.js) ===
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
